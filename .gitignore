mobile-v3/emulator/
mobile-v3/build-tools/
mobile-v3/platform-tools/
mobile-v3/platforms/
mobile-v3/sources/
mobile-v3/system-images/
mobile-v3/skins/
mobile-v3/licenses/

# OS/editor noise
.DS_Store
Thumbs.db
*.log
